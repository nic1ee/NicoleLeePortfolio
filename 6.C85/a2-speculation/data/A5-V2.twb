      <aliases enabled='yes' />
      <column caption='Is Substantiated' datatype='integer' name='[Calculation_0079415279972352]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF STARTSWITH(LOWER(TRIM([board_disposition])), &quot;substantiated&quot;)&#10;THEN 1&#10;ELSE 0&#10;END' />
      </column>
      <column caption='Substantiation Rate' datatype='real' name='[Calculation_0079415280041985]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Calculation_0079415279972352])' />
      </column>
      <column caption='Position' datatype='string' name='[Calculation_0079415286849540]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [complainant_ethnicity] = &quot;Black&quot; THEN &quot;Lowest&quot;&#10;ELSEIF [complainant_ethnicity] = &quot;American Indian&quot; THEN &quot;Highest&quot;&#10;END' />
        <aliases>
          <alias key='&quot;Highest&quot;' value='American Indian' />
          <alias key='&quot;Lowest&quot;' value='Black' />
        </aliases>
      </column>
