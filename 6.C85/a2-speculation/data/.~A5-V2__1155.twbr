            <column caption='Is Substantiated' datatype='integer' name='[Calculation_0079415279972352]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='IF STARTSWITH(LOWER(TRIM([board_disposition])), &quot;substantiated&quot;)&#10;THEN 1&#10;ELSE 0&#10;END' />
            </column>
