      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#000000' fontname='American Typewriter'>Substantiation Rates Are Similar Across Complainant Ethnicities</run>
            <run>Æ&#10;&#10;</run>
            <run fontcolor='#000000' fontname='American Typewriter' fontsize='10'>Differences are modest and largely fall within a 12-percentage-point band</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='allegations_202007271729' name='federated.064tddy0boh2af1h4hhqs10ewbpv' />
