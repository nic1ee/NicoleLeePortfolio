        <title>
          <formatted-text>
            <run fontcolor='#000000' fontname='Copperplate' fontsize='28'>A 12-Percentage-Point Gap in Substantiation Rates</run>
            <run>Æ&#10;&#10;</run>
            <run fontcolor='#000000' fontname='Copperplate' fontsize='12'>The Highest Substantiation Rate Is 50% Greater Than the Lowest</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='allegations_202007271729' name='federated.064tddy0boh2af1h4hhqs10ewbpv' />
